{
  "name": "lxcookie-manager",
  "displayName": "LXCookie Manager",
  "version": "1.4.0",
  "description": "高级Cookie管理，支持白名单/黑名单功能和选择性Cookie清除",
  "type": "module",
  "packageManager": "bun@1.3.13",
  "scripts": {
    "dev": "wxt",
    "prepare:wxt": "wxt prepare",
    "postinstall": "bun run prepare:wxt",
    "prepare:cookie-data": "bun scripts/update-tracker-data.ts",
    "prepare:cookie-data:allow-failure": "bun scripts/update-tracker-data.ts --allow-failure",
    "prepare:cookie-data:release": "bun scripts/update-tracker-data.ts --require-easyprivacy --enforce-freshness",
    "verify:cookie-baseline": "bun scripts/verify-cookie-baseline.ts",
    "build:dist": "wxt build",
    "build:analyze": "wxt build --analyze",
    "build": "bun run prepare:cookie-data && bun run build:dist",
    "build:local": "bun run prepare:cookie-data:allow-failure && bun run build:dist",
    "zip:dist": "wxt zip --browser chrome",
    "zip": "bun run prepare:cookie-data && bun run zip:dist",
    "zip:local": "bun run prepare:cookie-data:allow-failure && bun run zip:dist",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,css}\"",
    "tsc:version": "tsc --version",
    "type-check": "tsc --noEmit",
    "changelog": "git-cliff --output CHANGELOG.md",
    "changelog:latest": "git-cliff --latest"
  },
  "dependencies": {
    "@wxt-dev/i18n": "^0.2.5",
    "lucide-react": "^1.8.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "wxt": "^0.20.25"
  },
  "devDependencies": {
    "@types/bun": "^1.3.13",
    "@types/chrome": "0.1.40",
    "@types/node": "25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "@wxt-dev/module-react": "^1.2.2",
    "eslint": "~10.2.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "git-cliff": "^2.9.1",
    "globals": "^17.5.0",
    "license-checker-rseidelsohn": "4.4.2",
    "prettier": "^3.8.2",
    "typescript": "^5.9.3",
    "vite": "^8.0.8"
  },
  "overrides": {
    "msgpackr": "1.11.8",
    "content-security-policy-parser": "0.6.0",
    "svelte": "4.2.19",
    "esbuild": "0.25.0",
    "flatted": ">=3.4.2",
    "node-forge": ">=1.4.0",
    "picomatch": ">=4.0.4",
    "defu": ">=6.1.5",
    "vite": "8.0.8",
    "uuid": ">=14.0.0"
  }
}