{
  "name": "cookie-manager-pro",
  "displayName": "Cookie Manager Pro",
  "version": "1.1.5",
  "description": "高级Cookie管理，支持白名单/黑名单功能和选择性Cookie清除",
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "dev": "wxt",
    "build": "wxt build",
    "zip": "wxt zip --browser chrome",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,css}\"",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "changelog": "git-cliff --output CHANGELOG.md",
    "changelog:latest": "git-cliff --latest"
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "wxt": "^0.20.19"
  },
  "devDependencies": {
    "@playwright/test": "1.58.2",
    "license-checker-rseidelsohn": "4.4.2",
    "@testing-library/dom": "10.0.0",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/chrome": "0.0.258",
    "@types/node": "20.19.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@typescript-eslint/eslint-plugin": "^8.55.0",
    "@typescript-eslint/parser": "^8.55.0",
    "@vitest/coverage-istanbul": "4.0.18",
    "@vitest/ui": "4.0.18",
    "@wxt-dev/module-react": "^1.2.2",
    "eslint": "~9.21.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.5.0",
    "globals": "^17.3.0",
    "happy-dom": "^20.6.0",
    "jsdom": "^28.0.0",
    "prettier": "^3.8.1",
    "tar": "^7.5.11",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "4.0.18"
  },
  "overrides": {
    "msgpackr": "1.11.8",
    "content-security-policy-parser": "0.6.0",
    "svelte": "4.2.19",
    "esbuild": "0.25.0"
  }
}
